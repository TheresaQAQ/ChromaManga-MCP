# ─── LLM 配置（OpenAI 兼容端点）────────────────────────────────
# 拷贝为 .env.agent 并填入真实 API Key

# DeepSeek（推荐，便宜且工具调用稳定）
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 或 OpenAI：
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# 或 Qwen（阿里云 DashScope 兼容模式）：
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# 或 Kimi：
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k

LLM_TEMPERATURE=0.2
LLM_TIMEOUT=60

# ─── MCP Server 启动配置 ────────────────────────────────────
# 指向能跑 mcp_server/chromamanga_mcp_server.py 的 python 解释器
# 留空则默认使用当前运行 agent server 的 python
# MCP_PYTHON=D:\envs\chromamanga\python.exe

# ─── Agent 运行参数 ─────────────────────────────────────────
# ReAct 循环最大步数（create_task + 7 步 + get_result ≈ 10 步，留出余量）
AGENT_RECURSION_LIMIT=50

# FastAPI 监听地址
AGENT_HOST=127.0.0.1
AGENT_PORT=8000

# ─── 运行模式 ───────────────────────────────────────────────
# real = 启动真 MCP 子进程，跑 SDXL 推理（需要 GPU + 全部模型文件在本机）
# mock = 使用 agent/mock_tools.py 的假工具，不启动 MCP，不依赖模型
#        用于：在开发机上调前端 / 调 Agent 循环 / 给人演示界面
AGENT_MCP_MODE=real
